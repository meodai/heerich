{
  "name": "heerich",
  "version": "0.3.0",
  "description": "A tiny engine for 3D voxel scenes rendered to SVG",
  "type": "module",
  "main": "./dist/heerich.umd.cjs",
  "module": "./dist/heerich.js",
  "exports": {
    ".": {
      "import": "./dist/heerich.js",
      "require": "./dist/heerich.umd.cjs"
    }
  },
  "files": [
    "dist",
    "src/heerich.js"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "build:site": "vite build --config vite.site.config.js",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.js\" \"*.js\" \"*.css\" \"*.html\"",
    "format:check": "prettier --check \"src/**/*.js\" \"*.js\" \"*.css\" \"*.html\"",
    "test": "vitest run",
    "test:headed": "vitest run --config vitest.headed.config.js",
    "bench": "node bench.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "voxel",
    "svg",
    "3d",
    "isometric",
    "oblique",
    "perspective",
    "generative"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/meodai/heerich.git"
  },
  "bugs": "https://github.com/meodai/heerich/issues",
  "homepage": "https://meodai.github.io/heerich/",
  "author": "meodai",
  "license": "MIT",
  "devDependencies": {
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@webgpu/types": "^0.1.69",
    "fast-check": "^4.6.0",
    "mitata": "^1.0.34",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
